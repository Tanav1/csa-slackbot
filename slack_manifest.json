{
  "display_information": {
    "name": "Unanswered Message Alert",
    "description": "Watches channels and alerts when a message goes unanswered for too long.",
    "background_color": "#2c2d30"
  },
  "features": {
    "bot_user": {
      "display_name": "Unanswered Alert",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "channels:history",
        "channels:read",
        "groups:history",
        "groups:read",
        "reactions:read",
        "users:read",
        "chat:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "message.channels",
        "message.groups",
        "reaction_added"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
