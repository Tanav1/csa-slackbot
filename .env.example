# Slack Bot Token — starts with xoxb-
# Found in: Slack App Dashboard → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack App-Level Token — starts with xapp-
# Found in: Slack App Dashboard → Basic Information → App-Level Tokens
SLACK_APP_TOKEN=xapp-your-app-token-here

# Comma-separated list of channel IDs to monitor (public OR private)
# To find a channel ID: right-click the channel → View channel details → scroll to bottom
# Example: MONITORED_CHANNEL_IDS=C12345678,C98765432
MONITORED_CHANNEL_IDS=C12345678,C98765432

# The channel where unanswered-message alerts will be posted
ALERT_CHANNEL_ID=C00000000

# How long (in minutes) before a message is considered unanswered (default: 120)
RESPONSE_TIMEOUT_MINUTES=120
